{
  "name": "pdf-viewer-demo",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/pdf-viewer-demo/src",
  "prefix": "pdf-demo",
  "projectType": "application",
  "tags": ["type:app", "scope:demo"],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath.base}"],
      "options": {
        "outputPath": {
          "base": "apps/docs/public/demos/pdf-viewer",
          "browser": ""
        },
        "deleteOutputPath": true,
        "index": "apps/pdf-viewer-demo/src/index.html",
        "browser": "apps/pdf-viewer-demo/src/main.ts",
        "tsConfig": "apps/pdf-viewer-demo/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": ["apps/pdf-viewer-demo/src/favicon.ico", "apps/pdf-viewer-demo/src/assets"],
        "styles": ["apps/pdf-viewer-demo/src/styles.scss"],
        "scripts": [],
        "baseHref": "/demos/pdf-viewer/"
      },
      "configurations": {
        "production": {
          "budgets": [
            { "type": "initial", "maximumWarning": "2mb", "maximumError": "4mb" },
            { "type": "anyComponentStyle", "maximumWarning": "30kb", "maximumError": "60kb" }
          ],
          "fileReplacements": [
            {
              "replace": "apps/pdf-viewer-demo/src/environments/environment.ts",
              "with": "apps/pdf-viewer-demo/src/environments/environment.prod.ts"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "namedChunks": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "pdf-viewer-demo:build:production"
        },
        "development": {
          "buildTarget": "pdf-viewer-demo:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "test": {
      "executor": "@nx/angular:unit-test",
      "options": {}
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
